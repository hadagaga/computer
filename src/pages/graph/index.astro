---
import KnowledgeGraph from '../../components/graph/KnowledgeGraph';
import nodes from '../../data/nodes.json';
import edges from '../../data/edges.json';
import '../../styles/custom.css';
import '../../styles/graph-standalone.css';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="计算机体系视频百科全局知识图" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>全局知识图 | 计算机体系视频百科</title>
	</head>
	<body class="standalone-graph-page">
		<header class="standalone-graph-header">
			<div class="standalone-graph-title">
				<a href="/" aria-label="返回计算机体系视频百科首页">计算机体系视频百科</a>
				<span aria-hidden="true">/</span>
				<h1>全局知识图</h1>
			</div>
			<div class="graph-legend" aria-label="节点领域图例">
				<span><i class="legend-dot legend-dot--network"></i>计算机网络</span>
				<span><i class="legend-dot legend-dot--system"></i>操作系统</span>
				<span><i class="legend-dot legend-dot--application"></i>应用</span>
				<span><i class="legend-dot legend-dot--security"></i>网络安全</span>
			</div>
			<a class="standalone-docs-link" href="/nodes/">节点文档</a>
		</header>
		<main class="standalone-graph-stage">
			<KnowledgeGraph nodes={nodes} edges={edges} navigateOnDoubleClick client:only="react" />
		</main>
	</body>
</html>
