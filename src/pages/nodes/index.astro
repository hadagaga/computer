---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import nodes from '../../data/nodes.json';

const domainNames: Record<string, string> = {
	application: '应用',
	network: '计算机网络',
	security: '网络安全',
	system: '操作系统',
};
---

<StarlightPage frontmatter={{ title: '节点文档', description: '按领域浏览计算机体系知识节点及其内容状态。' }}>
	<div class="node-index-page">
		<header class="graph-page-header">
			<div class="graph-kicker">NODE DOCUMENTS · {nodes.length} NODES</div>
			<p>节点页沉淀概念定义、视频进度、直接关系及其参与的学习路径。也可以前往<a href="/graph/">独立知识图</a>从关系网络开始探索。</p>
		</header>
		<div class="node-index-grid">
			{nodes.map((node) => (
				<article class:list={['node-index-card', { 'node-index-card--available': node.url }]}>
					<div class="node-index-card__meta">
						<span>{domainNames[node.domain] ?? node.domain}</span>
						<span>{node.url ? '已有文档' : '规划中'}</span>
					</div>
					<h2>{node.url ? <a href={node.url}>{node.title}</a> : node.title}</h2>
					<p>{node.summary}</p>
					{node.url && <a class="node-index-card__link" href={node.url}>阅读节点 <span>→</span></a>}
				</article>
			))}
		</div>
	</div>
</StarlightPage>
